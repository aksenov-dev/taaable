    "deploy": "npm run build && cp dist/index.html dist/404.html && gh-pages -d dist"
  },
  "dependencies": {
    "@floating-ui/vue": "^1.1.11",
    "@vueuse/core": "^14.2.1",
    "dompurify": "^3.4.0",
    "idb": "^8.0.3",
    "nanoid": "^5.1.9",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "gh-pages": "^6.3.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.2",
    "npm-run-all2": "^8.0.4",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.3",
    "vite": "^8.0.8",
